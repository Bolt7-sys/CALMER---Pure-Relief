# ── CALMER Server Environment ──
# Leave MONGO_URI blank to run with the built-in in-memory store (great for
# quick demos on Netlify/Pandastack). Set it to persist data with MongoDB.
MONGO_URI=

# JWT signing secret — CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=30d

# Server port
PORT=5000

# Allowed client origin for CORS (use your deployed client URL in production)
CLIENT_ORIGIN=*
